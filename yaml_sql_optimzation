name: Super-Linter + SQL/PLSQL CI/CD
name: SQL/PLSQL CI/CD Pipeline

on:
  push:
    paths:
      - "sql/**"
      - "plsql/**"
    branches:
      - main
  pull_request:
    paths:
      - "sql/**"
      - "plsql/**"

jobs:
  oracle-ci:
    runs-on: ubuntu-latest

    services:
      oracle:
        image: gvenzl/oracle-xe:21-slim
        ports:
          - 1521:1521
        env:
          ORACLE_PASSWORD: oracle
        options: >-
          --health-cmd="echo 'SELECT 1 FROM dual;' | sqlplus -s system/oracle@localhost/XEPDB1"
          --health-interval=10s
          --health-timeout=5s
          --health-retries=10

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Install Oracle Instant Client
        run: |
          sudo apt-get update
          sudo apt-get install -y libaio1 wget unzip
          wget https://download.oracle.com/otn_software/linux/instantclient/instantclient-basiclite-linux.x64-21.11.0.0.0dbru.zip
          wget https://download.oracle.com/otn_software/linux/instantclient/instantclient-sqlplus-linux.x64-21.11.0.0.0dbru.zip
          unzip instantclient-basiclite-linux*.zip
          unzip instantclient-sqlplus-linux*.zip
          echo "$PWD/instantclient_21_11" >> $GITHUB_PATH
          echo "LD_LIBRARY_PATH=$PWD/instantclient_21_11" >> $GITHUB_ENV

      - name: Wait for Oracle to be ready
        run: sleep 60

      - name: Run SQLFluff Linter
        run: |
          pip install sqlfluff
          sqlfluff lint sql/ --dialect oracle
          sqlfluff lint plsql/ --dialect oracle

      - name: Load baseline schema
        run: |
          for file in ci-db-baseline/*.sql; do
            echo "Running $file"
            echo "@/github/workspace/$file" | sqlplus system/oracle@localhost/XEPDB1
          done

      - name: Apply migration scripts
        run: |
          for file in sql/migrations/*.sql; do
            echo "Running migration $file"
            echo "@/github/workspace/$file" | sqlplus system/oracle@localhost/XEPDB1
          done

      - name: Recompile invalid objects
        run: |
          echo "
          BEGIN
            FOR rec IN (
              SELECT object_name, object_type
              FROM user_objects
              WHERE status = 'INVALID'
            ) LOOP
              EXECUTE IMMEDIATE 'ALTER ' || rec.object_type || ' ' || rec.object_name || ' COMPILE';
            END LOOP;
          END;
          /" | sqlplus system/oracle@localhost/XEPDB1

      - name: Run utPLSQL tests
        run: |
          echo "@plsql/run_utplsql_tests.sql" | sqlplus system/oracle@localhost/XEPDB1

  deploy-staging:
    needs: oracle-ci
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      - name: Deploy migration to STAGING
        run: |
          for file in sql/migrations/*.sql; do
            echo "Deploying $file to STAGING"
            echo "@/github/workspace/$file" | sqlplus system/oracle@staging-db/XEPDB1
          done
          echo "Recompile dependent objects on STAGING"
          echo "
          BEGIN
            FOR rec IN (
              SELECT object_name, object_type
              FROM user_objects
              WHERE status = 'INVALID'
            ) LOOP
              EXECUTE IMMEDIATE 'ALTER ' || rec.object_type || ' ' || rec.object_name || ' COMPILE';
            END LOOP;
          END;
          /" | sqlplus system/oracle@staging-db/XEPDB1

  deploy-production:
    needs: deploy-staging
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4
      - name: Deploy migration to PRODUCTION
        run: |
          for file in sql/migrations/*.sql; do
            echo "Deploying $file to PRODUCTION"
            echo "@/github/workspace/$file" | sqlplus system/oracle@production-db/XEPDB1
          done
          echo "Recompile dependent objects on PRODUCTION"
          echo "
          BEGIN
            FOR rec IN (
              SELECT object_name, object_type
              FROM user_objects
              WHERE status = 'INVALID'
            ) LOOP
              EXECUTE IMMEDIATE 'ALTER ' || rec.object_type || ' ' || rec.object_name || ' COMPILE';
            END LOOP;
          END;
          /" | sqlplus system/oracle@production-db/XEPDB1
